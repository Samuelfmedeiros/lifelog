---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import DateSeparator from '../components/DateSeparator.astro';
import FilterBar from '../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const locale = 'pt';
const allPosts = await getCollection('posts');
const posts = allPosts.filter(p => !p.data.draft && !p.id.startsWith('en/'));
const sortDate = (p) => p.data.pubDate?.getTime() || p.data.date.getTime();
posts.sort((a, b) => sortDate(b) - sortDate(a));

// Search index: build at compile time
const searchIndex = posts.filter(p => !p.data.draft).map(p => ({
  id: p.id, slug: p.id.replace(/^(en\/)?/, ''),
  title: p.data.title, description: p.data.description,
  tags: p.data.tags, project: p.data.project,
  date: (p.data.pubDate || p.data.date).toISOString().slice(0, 10),
}));

const grouped = [];
const dateMap = new Map();
for (const post of posts) {
  const groupDate = post.data.pubDate || post.data.date;
  const dateKey = groupDate.toISOString().split('T')[0];
  if (!dateMap.has(dateKey)) {
    dateMap.set(dateKey, []);
  }
  dateMap.get(dateKey).push(post);
}
for (const [dateKey, dayPosts] of dateMap) {
  grouped.push({ date: dayPosts[0].data.pubDate || dayPosts[0].data.date, posts: dayPosts });
}

const getPubDate = (p) => p.data.pubDate || p.data.date;
const years = [...new Set(posts.map(p => getPubDate(p).getFullYear().toString()))].sort().reverse();

// Projetos que têm posts
const availableProjects = [...new Set(posts.map(p => p.data.project).filter(Boolean))];

const t = (await import('../lib/i18n')).getTranslations(locale);
const subtitleHtml = 'A jornada de aprendizado de <strong style="color: var(--color-accent)">Samuel Medeiros</strong>';
---

<BaseLayout title={t.home.title} description={t.home.description} locale={locale}>
  <section class="mb-12 text-center">
    <h1 class="hero-title">📖 LifeLog</h1>
    <p class="hero-subtitle" set:html={subtitleHtml}></p>
    <p class="text-sm mt-2" style="color: var(--color-text-muted)">{t.home.subtitle}</p>
  </section>

  <FilterBar years={years} locale={locale} availableProjects={availableProjects} searchIndex={JSON.stringify(searchIndex)} />

  <div class="timeline">
    {grouped.length === 0 && (
      <div id="empty-state" class="text-center py-20">
        <p class="text-lg" style="color: var(--color-text-muted)">Nenhum post encontrado 😢</p>
        <p class="text-sm mt-2" style="color: var(--color-text-muted)">Tenta mudar os filtros</p>
      </div>
    )}
    {grouped.map((group) => (
      <>
        <DateSeparator date={group.date} />
        <div class="flex flex-wrap justify-center gap-4">
          {group.posts.map((post, i) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              project={post.data.project}
              tags={post.data.tags}
              slug={post.id}
              icon={post.data.icon}
              cover={post.data.cover}
              index={i}
              locale={locale}
            />
          ))}
        </div>
      </>
    ))}
  </div>
</BaseLayout>
