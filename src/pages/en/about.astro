---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalWidget from '../../components/TerminalWidget.astro';
import { getCollection } from 'astro:content';

const locale = 'en';
const allPosts = await getCollection('posts');
const posts = allPosts.filter(p => !p.data.draft && p.id.startsWith('en/'));
const totalPosts = posts.length;
const projects = [...new Set(posts.map(p => p.data.project))].length;
const firstDate = posts.reduce((earliest, p) => p.data.date < earliest ? p.data.date : earliest, new Date());

const t = (await import('../../lib/i18n')).getTranslations(locale);
---

<BaseLayout title={t.about.title} description={t.about.description} locale={locale}>
  <article class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-extrabold mb-6" style="color: var(--color-heading)">{t.about.title}</h1>

    <div class="prose max-w-none" style="color: var(--color-text)">
      <p>{t.about.p1}</p>
      <p>{t.about.p2}</p>

      <hr style="border-color: var(--color-border); margin: 2rem 0;" />

      <h2 class="text-xl font-bold" style="color: var(--color-heading)">📊 Statistics</h2>
      <div class="grid grid-cols-3 gap-4 my-6">
        <div class="p-4 rounded-xl text-center" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
          <p class="text-2xl font-bold" style="color: var(--color-accent)">{totalPosts}</p>
          <p class="text-xs" style="color: var(--color-text-muted)">Posts</p>
        </div>
        <div class="p-4 rounded-xl text-center" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
          <p class="text-2xl font-bold" style="color: var(--color-accent)">{projects}</p>
          <p class="text-xs" style="color: var(--color-text-muted)">Projects</p>
        </div>
        <div class="p-4 rounded-xl text-center" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
          <p class="text-2xl font-bold" style="color: var(--color-accent)">{firstDate.getFullYear()}</p>
          <p class="text-xs" style="color: var(--color-text-muted)">Since</p>
        </div>
      </div>

      <hr style="border-color: var(--color-border); margin: 2rem 0;" />

      <h2 class="text-xl font-bold" style="color: var(--color-heading)">🔗 Links</h2>
      <ul style="list-style: none; padding: 0;">
        <li class="mb-2">
          <a href={t.about.portfolioUrl} target="_blank" rel="noopener" style="color: var(--color-accent)">
            {t.about.portfolio}
          </a>
        </li>
        <li class="mb-2">
          <a href="/rss.xml" style="color: var(--color-accent)">
            📡 RSS Feed
          </a>
        </li>
      </ul>
    </div>

    <TerminalWidget locale={locale} />
  </article>
</BaseLayout>
