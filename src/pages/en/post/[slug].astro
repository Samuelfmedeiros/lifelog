---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectIcon from '../../../components/ProjectIcon.astro';
import { getCollection, render } from 'astro:content';

const locale = 'en';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const posts = allPosts.filter(p => !p.data.draft && p.id.startsWith('en/'));
  return posts.map((post) => ({
    params: { slug: post.id.replace('en/', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const projectIcons = {
  arachne: '🕷️', dogwalk: '🐶', portfolio: '🚀',
  capivara: '🐷', estudos: '📚', descobertas: '💡',
};
const projectLabels = {
  arachne: 'Arachne', dogwalk: 'Dogwalk', portfolio: 'Portfolio',
  capivara: 'Capivara', estudos: 'Studies', descobertas: 'Discoveries',
};

const allPosts = await getCollection('posts');
const localePosts = allPosts.filter(p => !p.data.draft && (p.data.lang || 'pt') === locale);
localePosts.sort((a, b) => {
  const aSort = (a.data.pubDate || a.data.date).getTime();
  const bSort = (b.data.pubDate || b.data.date).getTime();
  return bSort - aSort;
});
const currentIndex = localePosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < localePosts.length - 1 ? localePosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? localePosts[currentIndex - 1] : null;

const coverImage = post.data.cover;
const readingTime = Math.max(1, Math.ceil((post.body?.length || 0) / 1000));
const readLabel = `${readingTime} min read`;
const backText = '← Back to timeline';
const prevLabel = '← Previous post';
const nextLabel = 'Next post →';
function fmtDate(d) {
  return d.toLocaleDateString('en-US', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<BaseLayout title={post.data.title} description={post.data.description} theme={post.data.project} image={coverImage} type="article" locale={locale}>
  <article data-project={post.data.project}>
    <div class="max-w-3xl mx-auto px-4 py-8">
      <div class="relative w-full aspect-[21/9] mb-10 rounded-2xl overflow-hidden border" style="border-color: var(--color-accent); box-shadow: var(--color-glow);">
        {coverImage ? (
          <img src={coverImage} alt={post.data.title} class="absolute inset-0 w-full h-full object-cover" />
        ) : (
          <>
        <div class="absolute inset-0" style="background: var(--bg-gradient);"></div>
        <div class="absolute inset-0" style="background-image: var(--pattern-url); background-size: 120px; opacity: var(--pattern-opacity); background-blend-mode: var(--pattern-blend);"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span style="font-size: 5rem; filter: drop-shadow(0 0 40px var(--color-accent)); opacity: 0.6;">
            {projectIcons[post.data.project] || '📝'}
          </span>
        </div>
        </>
        )}
        <div class="absolute bottom-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, transparent, var(--color-accent), transparent);"></div>
      </div>

      <header class="mb-12">
        <div class="flex items-center gap-2 text-sm mb-4" style="color: var(--color-accent);">
          <span>{projectIcons[post.data.project]} {projectLabels[post.data.project] || post.data.project}</span>
          <span class="opacity-40">·</span>
          <time datetime={(post.data.pubDate || post.data.date).toISOString()} style="color: var(--color-text-muted)">
            {post.data.pubDate ? fmtDate(post.data.pubDate) : fmtDate(post.data.date)}
          </time>
        </div>

        <h1 class="text-4xl font-bold mb-4 leading-tight" style="color: var(--color-heading)">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-3 text-sm mb-6" style="color: var(--color-text-muted);">
          <span>📖 {readLabel}</span>
          <span class="w-1 h-1 rounded-full bg-current opacity-40" />
          <a href="/en/" style="color: var(--color-accent); text-decoration: none;"
             class="hover:underline">{backText}</a>
        </div>

        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={`/en/?tag=${tag}`}
              class="px-3 py-1 text-xs rounded-full border transition-colors"
              style="border-color: var(--color-accent); color: var(--color-accent); background: var(--color-accent-soft);"
            >#{tag}</a>
          ))}
        </div>
      </header>

      <div class="prose prose-lg max-w-none" style="color: var(--color-text);">
        <Content />
      </div>

      <nav class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
        <div class="grid grid-cols-2 gap-6">
          <div>
            {prevPost && (
              <a href={`/en/post/${prevPost.id.replace('en/', '')}`} class="group block no-underline!">
                <span class="text-xs font-medium tracking-wider uppercase" style="color: var(--color-text-muted);">
                  {prevLabel}
                </span>
                <span class="block mt-1 text-sm font-medium group-hover:underline"
                      style="color: var(--color-accent);">
                  {projectIcons[prevPost.data.project]} {prevPost.data.title}
                </span>
              </a>
            )}
          </div>
          <div class="text-right">
            {nextPost && (
              <a href={`/en/post/${nextPost.id.replace('en/', '')}`} class="group block no-underline!">
                <span class="text-xs font-medium tracking-wider uppercase" style="color: var(--color-text-muted);">
                  {nextLabel}
                </span>
                <span class="block mt-1 text-sm font-medium group-hover:underline"
                      style="color: var(--color-accent);">
                  {nextPost.data.title} {projectIcons[nextPost.data.project]}
                </span>
              </a>
            )}
          </div>
        </div>

        <div class="mt-6 text-center">
          <a href="/en/" class="inline-flex items-center gap-1 text-sm font-medium hover:underline no-underline!"
             style="color: var(--color-accent);">
            {backText}
          </a>
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>

<style is:global>
  article[data-project] .prose h2 { font-size: 1.75rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; padding-bottom: 0.5rem; color: var(--color-heading); border-bottom: 1px solid var(--color-border); }
  article[data-project] .prose h3 { font-size: 1.35rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--color-text); }
  article[data-project] .prose p { line-height: 1.8; margin-bottom: 1.25rem; }
  article[data-project] .prose code { font-size: 0.875rem; padding: 0.2rem 0.4rem; border-radius: 4px; background: var(--color-accent-soft); color: var(--color-accent); border: 1px solid var(--color-border); }
  article[data-project] .prose pre { padding: 1.25rem; border-radius: 12px; background: var(--color-bg-card); border: 1px solid var(--color-border); overflow-x: auto; margin-bottom: 1.5rem; }
  article[data-project] .prose pre code { background: none; border: none; padding: 0; color: var(--color-text); }
  article[data-project] .prose a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px; }
  article[data-project] .prose a:hover { opacity: 0.8; }
  article[data-project] .prose ul, article[data-project] .prose ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  article[data-project] .prose li { margin-bottom: 0.5rem; line-height: 1.7; }
  article[data-project] .prose blockquote { border-left: 3px solid var(--color-accent); padding-left: 1rem; margin: 1.5rem 0; font-style: italic; color: var(--color-text-muted); background: var(--color-accent-soft); padding: 1rem 1rem 1rem 1.5rem; border-radius: 8px; }
  article[data-project] .prose img { border-radius: 12px; margin: 1.5rem auto; border: 1px solid var(--color-border); }
  article[data-project] .prose hr { border-color: var(--color-border); margin: 2rem 0; }
  article[data-project] .prose strong { color: var(--color-heading); }
  .prose .highlight-box { background: var(--color-accent-soft); border: 1px solid var(--color-accent); border-radius: 12px; padding: 1.25rem; margin: 1.5rem 0; color: var(--color-accent); font-weight: 500; }
  @media (max-width: 768px) {
    article[data-project] h1 { font-size: 1.5rem !important; }
    article[data-project] .prose h2 { font-size: 1.35rem !important; }
    article[data-project] .prose h3 { font-size: 1.1rem !important; }
    article[data-project] .prose p, article[data-project] .prose li { font-size: 0.9375rem; }
    article[data-project] .prose pre { padding: 0.875rem !important; font-size: 0.8125rem; }
  }
</style>
