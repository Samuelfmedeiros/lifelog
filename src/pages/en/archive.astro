---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectIcon from '../../components/ProjectIcon.astro';
import { getCollection } from 'astro:content';

const locale = 'en';
const allPosts = await getCollection('posts');
const posts = allPosts.filter(p => !p.data.draft && p.id.startsWith('en/'));
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const byYear = new Map();
for (const post of posts) {
  const year = post.data.date.getFullYear().toString();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year).push(post);
}
const years = [...byYear.keys()].sort().reverse();

const projectCount = new Map();
for (const post of posts) {
  const p = post.data.project;
  projectCount.set(p, (projectCount.get(p) || 0) + 1);
}

const t = (await import('../../lib/i18n')).getTranslations(locale);
---

<BaseLayout title={t.archive.pageTitle} description={t.archive.description} locale={locale}>
  <h1 class="text-3xl font-extrabold mb-2" style="color: var(--color-heading)">{t.archive.title}</h1>
  <p class="mb-8" style="color: var(--color-text-muted)">{posts.length} posts total</p>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-12">
    {[...projectCount.entries()].map(([proj, count]) => (
      <div class="p-4 rounded-xl" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
        <ProjectIcon project={proj} />
        <p class="text-lg font-bold mt-2" style="color: var(--color-heading)">{count}</p>
        <p class="text-xs" style="color: var(--color-text-muted)">{proj}</p>
      </div>
    ))}
  </div>

  {years.map((year) => (
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4" style="color: var(--color-accent)">{year}</h2>
      <div class="space-y-2">
        {byYear.get(year).map((post) => (
          <a
            href={`/en/post/${post.id.replace('en/', '')}`}
            class="flex items-center gap-3 p-3 rounded-lg text-sm hover:opacity-80 transition no-underline!"
            style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-text);"
          >
            <ProjectIcon project={post.data.project} emoji={post.data.icon} />
            <div class="flex-1 min-w-0">
              <span class="font-medium block truncate">{post.data.title}</span>
              <span class="text-xs" style="color: var(--color-text-muted)">
                {post.data.date.toLocaleDateString('en-US')}
              </span>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--color-accent-soft); color: var(--color-accent);">
              {post.data.project}
            </span>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
