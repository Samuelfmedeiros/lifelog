---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectIcon from '../../components/ProjectIcon.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

export async function load() {
  const posts = await getCollection('posts');
  posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return { posts };
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const projectIcons: Record<string, string> = {
  arachne: '🕷️', dogwalk: '🐶', portfolio: '🚀',
  capivara: '🐷', estudos: '📚', descobertas: '💡',
};
const projectLabels: Record<string, string> = {
  arachne: 'Arachne', dogwalk: 'Dogwalk', portfolio: 'Portfólio',
  capivara: 'Capivara', estudos: 'Estudos', descobertas: 'Descobertas',
};

// Get prev/next posts
const allPosts = await getCollection('posts');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const coverImage = post.data.cover;
const readingTime = Math.max(1, Math.ceil((post.body?.length || 0) / 1000));
---

<BaseLayout title={post.data.title} description={post.data.description} theme={post.data.project}>
  <article data-project={post.data.project}>
    <div class="max-w-3xl mx-auto px-4 py-8">
      <!-- Cover Image -->
      <div class="relative w-full aspect-[21/9] mb-10 rounded-2xl overflow-hidden border" style="border-color: var(--color-accent); box-shadow: var(--color-glow);">
        <div class="absolute inset-0" style="background: var(--bg-gradient);"></div>
        <div class="absolute inset-0" style="background-image: var(--pattern-url); background-size: 120px; opacity: var(--pattern-opacity); background-blend-mode: var(--pattern-blend);"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span style="font-size: 5rem; filter: drop-shadow(0 0 40px var(--color-accent)); opacity: 0.6;">
            {projectIcons[post.data.project] || '📝'}
          </span>
        </div>
        <!-- Accent glow line -->
        <div class="absolute bottom-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, transparent, var(--color-accent), transparent);"></div>
      </div>

      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-2 text-sm mb-4" style="color: var(--color-accent);">
          <span>{projectIcons[post.data.project]} {projectLabels[post.data.project] || post.data.project}</span>
          <span class="opacity-40">·</span>
          <time datetime={post.data.date.toISOString()} style="color: var(--color-text-muted)">
            {post.data.date.toLocaleDateString('pt-BR', {
              day: '2-digit', month: 'long', year: 'numeric',
            })}
          </time>
        </div>

        <h1 class="text-4xl font-bold mb-4 leading-tight" style="color: #fff">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-3 text-sm mb-6" style="color: var(--color-text-muted);">
          <span>📖 {readingTime} min de leitura</span>
          <span class="w-1 h-1 rounded-full bg-current opacity-40" />
          <a href="/" style="color: var(--color-accent); text-decoration: none;"
             class="hover:underline">← timeline</a>
        </div>

        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={`/?tag=${tag}`}
              class="px-3 py-1 text-xs rounded-full border transition-colors"
              style="border-color: var(--color-accent); color: var(--color-accent); background: var(--color-accent-soft);"
            >#{tag}</a>
          ))}
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none" style="color: var(--color-text);">
        <Content />
      </div>

      <!-- Navigation: Prev / Next -->
      <nav class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
        <div class="grid grid-cols-2 gap-6">
          <div>
            {prevPost && (
              <a href={`/post/${prevPost.id}`} class="group block no-underline!">
                <span class="text-xs font-medium tracking-wider uppercase" style="color: var(--color-text-muted);">
                  ← Post anterior
                </span>
                <span class="block mt-1 text-sm font-medium group-hover:underline"
                      style="color: var(--color-accent);">
                  {projectIcons[prevPost.data.project]} {prevPost.data.title}
                </span>
              </a>
            )}
          </div>
          <div class="text-right">
            {nextPost && (
              <a href={`/post/${nextPost.id}`} class="group block no-underline!">
                <span class="text-xs font-medium tracking-wider uppercase" style="color: var(--color-text-muted);">
                  Próximo post →
                </span>
                <span class="block mt-1 text-sm font-medium group-hover:underline"
                      style="color: var(--color-accent);">
                  {nextPost.data.title} {projectIcons[nextPost.data.project]}
                </span>
              </a>
            )}
          </div>
        </div>

        <div class="mt-6 text-center">
          <a href="/" class="inline-flex items-center gap-1 text-sm font-medium hover:underline no-underline!"
             style="color: var(--color-accent);">
            ← Voltar para timeline
          </a>
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Prose content using theme colors */
  article[data-project] .prose h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    color: #fff;
    border-bottom: 1px solid var(--color-border);
  }
  article[data-project] .prose h3 {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  article[data-project] .prose p {
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  article[data-project] .prose code {
    font-size: 0.875rem;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
  }
  article[data-project] .prose pre {
    padding: 1.25rem;
    border-radius: 12px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  article[data-project] .prose pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
  }
  article[data-project] .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  article[data-project] .prose a:hover { opacity: 0.8; }
  article[data-project] .prose ul, article[data-project] .prose ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  article[data-project] .prose li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  article[data-project] .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-muted);
    background: var(--color-accent-soft);
    padding: 1rem 1rem 1rem 1.5rem;
    border-radius: 8px;
  }
  article[data-project] .prose img {
    border-radius: 12px;
    margin: 1.5rem auto;
    border: 1px solid var(--color-border);
  }
  article[data-project] .prose hr {
    border-color: var(--color-border);
    margin: 2rem 0;
  }
  article[data-project] .prose strong {
    color: #fff;
  }

  /* Highlight box */
  .prose .highlight-box {
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    border-radius: 12px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
