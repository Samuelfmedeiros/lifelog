---
export interface Props {
  title: string;
  description?: string;
  theme?: string;
}

const { title, description, theme } = Astro.props;
const pageTitle = `${title} — LifeLog`;
const pageDesc = description || 'Jornada de aprendizado de Samuel Medeiros';
const themeAttr = theme || 'dev';
---

<!DOCTYPE html>
<html lang="pt-BR" data-project={themeAttr}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="LifeLog RSS" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <header class="sticky top-0 z-50 glass">
      <nav class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-lg no-underline! hover:opacity-80 transition">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--color-accent-soft); border: 1px solid var(--color-accent); font-size: 1.1rem">
            📖
          </span>
          <span style="color: var(--color-accent)">LifeLog</span>
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href="/" class="hover:opacity-80 transition" style="color: var(--color-text-muted)">Início</a>
          <a href="/arquivo" class="hover:opacity-80 transition" style="color: var(--color-text-muted)">Arquivo</a>
          <a href="/sobre" class="hover:opacity-80 transition" style="color: var(--color-text-muted)">Sobre</a>
          <a href="https://samuelmedeiros.vercel.app" target="_blank" rel="noopener" class="flex items-center gap-1 px-3 py-1.5 rounded-full border transition" style="border-color: var(--color-accent); color: var(--color-accent); font-size: 0.75rem;">
            🚀 Portfólio
          </a>
        </div>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="max-w-4xl mx-auto px-4 py-8 text-center text-xs" style="color: var(--color-text-muted); border-top: 1px solid var(--color-border);">
      <p>LifeLog © {new Date().getFullYear()} — A jornada de aprendizado de Samuel Medeiros</p>
      <p class="mt-1">
        <a href="/rss.xml" class="hover:underline" style="color: var(--color-accent)">RSS</a>
      </p>
    </footer>
  </body>
</html>
