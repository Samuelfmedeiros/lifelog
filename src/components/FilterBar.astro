---
// FilterBar v4 — Glass minimal
import { PROJECTS } from '../lib/projects';

export interface Props {
  years: string[];
  locale?: string;
  availableProjects?: string[]; // se passado, só mostra pills desses projetos
}
const { years, locale, availableProjects } = Astro.props;
const isEn = locale === 'en';
const searchPlaceholder = isEn ? 'Search posts...' : 'Buscar posts...';
const searchAria = isEn ? 'Search posts' : 'Buscar posts';
const filterAria = isEn ? 'Filter by project' : 'Filtrar por projeto';
const yearAria = isEn ? 'Filter by year' : 'Filtrar por ano';
const allLabel = isEn ? 'All' : 'Todos';
---

<div
  id="filter-bar"
  class="filter-bar"
>
  <!-- Row 1: Search -->
  <div class="search-row">
    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        id="filter-search"
        type="text"
        placeholder={searchPlaceholder}
        class="search-input"
        aria-label={searchAria}
      />
      <span class="search-hint"><kbd>⌘</kbd><kbd>K</kbd></span>
      <button id="search-clear" class="search-clear" aria-label="Limpar busca">×</button>
    </div>
    <span id="result-count" class="result-count"></span>
  </div>

  <!-- Row 2: Pills + Year -->
  <div class="filter-row">
    <div class="filter-pills" role="radiogroup" aria-label={filterAria}>
      {[{ id: 'all', label: allLabel }, ...PROJECTS].filter(
        p => p.id === 'all' || !availableProjects || availableProjects.includes(p.id)
      ).map((p) => (
        <button
          class="pill"
          data-filter-project={p.id}
          data-active={p.id === 'all'}
          aria-checked={p.id === 'all'}
          role="radio"
        >
          {p.label}
        </button>
      ))}
    </div>

    {years.length > 1 && (
      <div class="year-pills" role="radiogroup" aria-label={yearAria}>
        <button
          class="pill year-pill"
          data-filter-year="all"
          data-active="true"
          aria-checked="true"
          role="radio"
        >
          {allLabel}
        </button>
        {years.map((y) => (
          <button
            class="pill year-pill"
            data-filter-year={y}
            data-active="false"
            aria-checked="false"
            role="radio"
          >
            {y}
          </button>
        ))}
      </div>
    )}
  </div>
</div>

<script is:inline>
(function() {
  const bar = document.getElementById('filter-bar');
  const searchInput = document.getElementById('filter-search');
  const pills = document.querySelectorAll('[data-filter-project]');
  const yearPills = document.querySelectorAll('[data-filter-year]');

  // ═══════════════════════════════════════
  // PROJECT_ACCENTS — must match src/lib/projects.ts (single source of truth)
  // ═══════════════════════════════════════
  const PROJECT_ACCENTS = {
    arachne: '#7c3aed',
    dogwalk: '#22c55e',
    portfolio: '#00d4ff',
    capivara: '#f59e0b',
    tatuengine: '#14b8a6',
    seguranca: '#ef4444',
    lifelog: '#a855f7',
    estudos: '#3b82f6',
    descobertas: '#38bdf8',
  };
  const RGBS = {};
  function hexToRgb(hex) {
    if (RGBS[hex]) return RGBS[hex];
    const r = parseInt(hex.slice(1,3), 16);
    const g = parseInt(hex.slice(3,5), 16);
    const b = parseInt(hex.slice(5,7), 16);
    RGBS[hex] = `${r}, ${g}, ${b}`;
    return RGBS[hex];
  }

  let activeProject = 'all';
  let activeYear = 'all';
  let activeSearch = '';
  let debounceTimer = null;
  const resultCountEl = document.getElementById('result-count');
  const clearBtn = document.getElementById('search-clear');

  function setBarAccent(projectId) {
    if (projectId === 'all') {
      bar.removeAttribute('data-project');
      bar.style.setProperty('--bar-accent', '#848d97');
      bar.style.setProperty('--bar-accent-rgb', '132, 141, 151');
    } else {
      bar.setAttribute('data-project', projectId);
      const color = getComputedStyle(bar).getPropertyValue('--color-accent').trim();
      if (color) {
        const rgb = hexToRgb(color);
        bar.style.setProperty('--bar-accent', color);
        bar.style.setProperty('--bar-accent-rgb', rgb);
      }
    }
  }

  /** Set global site theme when clicking a project filter */
  function setGlobalTheme(projectId) {
    const html = document.documentElement;
    if (projectId === 'all') {
      html.removeAttribute('data-project');
      html.style.removeProperty('--color-accent');
      // Trigger PalettePicker reapply if palette was saved
      const savedPalette = localStorage.getItem('lifelog-palette');
      if (savedPalette) {
        const event = new CustomEvent('lifelog-palette-reapply', { detail: { palette: savedPalette } });
        document.dispatchEvent(event);
      }
    } else {
      html.setAttribute('data-project', projectId);
      const accent = PROJECT_ACCENTS[projectId];
      if (accent) {
        html.style.setProperty('--color-accent', accent);
      }
    }
  }

  // ===== Build post index from DOM =====
  function buildPostIndex() {
    const posts = document.querySelectorAll('.post-card');
    return Array.from(posts).map(post => ({
      el: post,
      project: post.getAttribute('data-project'),
      title: post.querySelector('h2')?.textContent || '',
      desc: post.querySelector('.card-desc')?.textContent || '',
      tags: Array.from(post.querySelectorAll('.tag')).map(t => t.textContent || ''),
      dateText: post.querySelector('[data-date]')?.textContent || '',
    }));
  }

  let postsData = buildPostIndex();

  // Rebuild on DOM changes — observa o body todo pq posts são renderizados depois deste script
  if (window.MutationObserver) {
    const obs = new MutationObserver(() => {
      postsData = buildPostIndex();
      if (activeSearch.length >= 2) {
        fuzzySearch(activeSearch);
      } else {
        filterPosts();
        updateResultCount();
      }
    });
    obs.observe(document.body, { childList: true, subtree: true });
    // Desliga depois de 3s (já deve ter capturado tudo)
    setTimeout(() => obs.disconnect(), 3000);
  }

  // ===== Project pill click =====
  pills.forEach(btn => {
    btn.addEventListener('click', () => {
      const project = btn.getAttribute('data-filter-project');
      if (!project) return;

      pills.forEach(b => {
        b.setAttribute('data-active', 'false');
        b.ariaChecked = 'false';
      });
      btn.setAttribute('data-active', 'true');
      btn.ariaChecked = 'true';

      activeProject = project;
      setBarAccent(project);
      setGlobalTheme(project);
      filterPosts();
    });
  });

  // ===== Year pill click =====
  yearPills.forEach(btn => {
    btn.addEventListener('click', () => {
      const year = btn.getAttribute('data-filter-year');
      if (!year) return;

      yearPills.forEach(b => {
        b.setAttribute('data-active', 'false');
        b.ariaChecked = 'false';
      });
      btn.setAttribute('data-active', 'true');
      btn.ariaChecked = 'true';

      activeYear = year;
      filterPosts();
    });
  });

  // ===== Search with debounced fuzzy =====
  searchInput.addEventListener('input', () => {
    activeSearch = searchInput.value.trim();
    clearBtn?.classList.toggle('show', !!activeSearch);
    clearTimeout(debounceTimer);
    if (activeSearch.length >= 2) {
      debounceTimer = setTimeout(() => fuzzySearch(activeSearch), 150);
    } else {
      debounceTimer = setTimeout(() => { filterPosts(); updateResultCount(); }, 50);
    }
  });

  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchInput.blur();
      searchInput.value = '';
      activeSearch = '';
      clearBtn?.classList.remove('show');
      clearTimeout(debounceTimer);
      filterPosts();
      updateResultCount();
      syncURL();
    }
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // ===== Filter logic (project + year only; search goes via fuzzySearch) =====
  function filterPosts() {
    postsData = buildPostIndex();

    postsData.forEach((pd) => {
      const yearMatch = pd.dateText.match(/\d{4}/);
      const year = yearMatch ? yearMatch[0] : '';

      const matchProject = activeProject === 'all' || pd.project === activeProject;
      const matchYear = activeYear === 'all' || year === activeYear;
      const visible = matchProject && matchYear;

      pd.el.classList.toggle('filter-hidden', !visible);
      pd.el.style.display = visible ? '' : 'none';
    });

    updateGroupVisibility();
  }

  function updateGroupVisibility() {
    document.querySelectorAll('.date-separator').forEach(sep => {
      let next = sep.nextElementSibling;
      let hasVisible = false;
      while (next && !next.classList.contains('date-separator')) {
        if (next.classList.contains('post-card') && next.style.display !== 'none') {
          hasVisible = true;
          break;
        }
        next = next.nextElementSibling;
      }
      sep.style.display = hasVisible ? '' : 'none';
    });

    const emptyEl = document.getElementById('empty-state');
    const visibleCount = postsData.filter(p => p.el.style.display !== 'none').length;
    if (emptyEl) {
      emptyEl.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  // ===== Fuzzy search (Fuse.js) =====
  async function fuzzySearch(query) {
    const q = query.toLowerCase().trim();
    if (q.length < 2) { filterPosts(); updateResultCount(); return; }
    postsData = buildPostIndex();

    // First filter by project + year
    const filtered = postsData.filter(pd => {
      const yearMatch = pd.dateText.match(/\d{4}/);
      const year = yearMatch ? yearMatch[0] : '';
      return (activeProject === 'all' || pd.project === activeProject) &&
             (activeYear === 'all' || year === activeYear);
    });

    try {
      const mod = await import('/vendor/fuse.mjs');
      const fuse = new mod.default(filtered, {
        keys: ['title', 'desc', 'tags', 'project'],
        threshold: 0.4,
        distance: 100,
        minMatchCharLength: 2,
      });
      const results = fuse.search(q);
      const matchedEls = new Set(results.map(r => r.item.el));

      postsData.forEach(pd => {
        const match = matchedEls.has(pd.el);
        pd.el.classList.toggle('filter-hidden', !match);
        pd.el.style.display = match ? '' : 'none';
      });
    } catch (e) {
      // Fallback: basic includes
      postsData.forEach(pd => {
        const match = pd.title.toLowerCase().includes(q) ||
                     pd.desc.toLowerCase().includes(q) ||
                     pd.tags.some(t => t.toLowerCase().includes(q)) ||
                     pd.project?.includes(q);
        pd.el.classList.toggle('filter-hidden', !match);
        pd.el.style.display = match ? '' : 'none';
      });
    }

    updateGroupVisibility();
    updateResultCount();
  }

  // ===== Result count =====
  function updateResultCount() {
    postsData = buildPostIndex();
    const visible = postsData.filter(p => p.el.style.display !== 'none').length;
    const total = postsData.length;
    if (resultCountEl) {
      if (visible < total || activeSearch || activeProject !== 'all' || activeYear !== 'all') {
        resultCountEl.textContent = `${visible} de ${total}`;
        resultCountEl.classList.add('visible');
      } else {
        resultCountEl.classList.remove('visible');
      }
    }
  }

  // ===== URL sync =====
  function syncURL() {
    const params = new URLSearchParams();
    if (activeSearch) params.set('q', activeSearch);
    if (activeProject !== 'all') params.set('project', activeProject);
    if (activeYear !== 'all') params.set('year', activeYear);
    const qs = params.toString();
    const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
    history.replaceState(null, '', url);
  }

  function readURLParams() {
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    const project = params.get('project');
    const year = params.get('year');
    if (q && searchInput) {
      searchInput.value = q;
      activeSearch = q;
      clearBtn?.classList.add('show');
    }
    if (project && project !== 'all') {
      const btn = document.querySelector(`[data-filter-project="${project}"]`);
      if (btn) {
        pills.forEach(b => { b.setAttribute('data-active', 'false'); b.ariaChecked = 'false'; });
        btn.setAttribute('data-active', 'true');
        btn.ariaChecked = 'true';
        activeProject = project;
        setBarAccent(project);
        setGlobalTheme(project);
      }
    }
    if (year && year !== 'all') {
      const btn = document.querySelector(`[data-filter-year="${year}"]`);
      if (btn) {
        yearPills.forEach(b => { b.setAttribute('data-active', 'false'); b.ariaChecked = 'false'; });
        btn.setAttribute('data-active', 'true');
        btn.ariaChecked = 'true';
        activeYear = year;
      }
    }
  }

  // ===== Tag click delegation =====
  document.addEventListener('click', function(e) {
    const tag = e.target.closest('.post-card .tag');
    if (tag) {
      e.preventDefault();
      const tagText = tag.textContent.trim();
      searchInput.value = tagText;
      activeSearch = tagText;
      clearBtn?.classList.add('show');
      clearTimeout(debounceTimer);
      fuzzySearch(tagText);
      syncURL();
    }
  });

  // ===== Init =====
  readURLParams();
  setBarAccent(activeProject);

  // Deferred: posts só entram no DOM depois que este script executa
  setTimeout(() => {
    filterPosts();
    updateResultCount();
  }, 0);
  requestAnimationFrame(() => {
    postsData = buildPostIndex();
    filterPosts();
    updateResultCount();
  });

  // Clear button
  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    activeSearch = '';
    clearBtn.classList.remove('show');
    clearTimeout(debounceTimer);
    filterPosts();
    updateResultCount();
    syncURL();
    searchInput.focus();
  });

  // Sync URL on pill clicks
  pills.forEach(btn => {
    btn.addEventListener('click', () => setTimeout(syncURL, 0));
  });
  yearPills.forEach(btn => {
    btn.addEventListener('click', () => setTimeout(syncURL, 0));
  });

  // Preserva scroll horizontal da barra quando paleta/tema muda
  let savedScroll = 0;
  const saveScroll = () => { if (bar) savedScroll = bar.scrollLeft; };
  const restoreScroll = () => { if (bar && savedScroll > 0) { requestAnimationFrame(() => { bar.scrollLeft = savedScroll; }); }};
  document.addEventListener('lifelog-theme-change', restoreScroll);
  document.addEventListener('lifelog-palette-change', restoreScroll);
  document.addEventListener('lifelog-palette-reapply', restoreScroll);
  // Salva scroll antes de qualquer clique em pills (que podem disparar eventos)
  bar?.addEventListener('scroll', saveScroll, { passive: true });
})();
</script>

<style>
  /* ═══════════════════════════════════════
     FilterBar v4 — Glass minimal
     ═══════════════════════════════════════ */
  .filter-bar {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    border-radius: 16px;

    /* ── Accent defaults (overridden by JS via theme CSS vars) ── */
    --bar-accent: #848d97;
    --bar-accent-rgb: 132, 141, 151;

    /* ── Theme-aware backgrounds (overridden by themes.css) ── */
    --filter-bar-bg: rgba(18, 18, 24, 0.55);
    --filter-bar-border: rgba(255, 255, 255, 0.06);
    --filter-search-bg: rgba(255, 255, 255, 0.04);
    --filter-search-border: rgba(255, 255, 255, 0.04);
    --filter-pill-hover-bg: rgba(255, 255, 255, 0.04);
    --filter-pill-hover-border: rgba(255, 255, 255, 0.06);

    /* ── Glass base ── */
    background: var(--filter-bar-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--filter-bar-border);

    /* ── Dynamic glow & tint via CSS color-mix ── */
    box-shadow:
      0 0 30px color-mix(in srgb, rgba(var(--bar-accent-rgb), 0.08), transparent),
      0 4px 24px rgba(0, 0, 0, 0.06);

    /* ── Ultra-smooth transitions ── */
    transition:
      background 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Glass tint shift via color-mix com a cor ativa */
  .filter-bar {
    /* O color-mix abaixo auto-atualiza quando --bar-accent-rgb muda */
    background:
      color-mix(in srgb, rgba(18, 18, 24, 0.55) 100%, rgba(var(--bar-accent-rgb), 0.06));
  }

  /* ════════ Search Row ════════ */
  .search-row {
    width: 100%;
  }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 12px;
    background: var(--filter-search-bg);
    border: 1px solid var(--filter-search-border);
    transition:
      border-color 0.4s ease,
      background 0.4s ease,
      box-shadow 0.4s ease;
  }
  .search-wrap:focus-within {
    border-color: rgba(var(--bar-accent-rgb), 0.3);
    background: rgba(var(--bar-accent-rgb), 0.04);
    box-shadow: 0 0 20px rgba(var(--bar-accent-rgb), 0.06);
  }

  .search-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    opacity: 0.35;
    transition: opacity 0.4s ease, color 0.4s ease;
    color: var(--color-text-muted);
  }
  .search-wrap:focus-within .search-icon {
    opacity: 0.7;
    color: var(--bar-accent);
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 0.875rem;
    font-family: inherit;
    min-width: 0;
  }
  .search-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  .search-hint {
    display: none;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }
  .search-hint kbd {
    font-size: 0.6rem;
    padding: 1px 5px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-muted);
    font-family: inherit;
    opacity: 0.35;
  }
  @media (min-width: 640px) {
    .search-hint { display: inline-flex; }
  }

  /* ════════ Filter Row ════════ */
  .filter-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-pills {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .year-pills {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
    margin-left: auto;
  }

  /* ════════ Pill — glass style ════════ */
  .pill {
    all: unset;
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: transparent;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    font-family: inherit;
    white-space: nowrap;
    line-height: 1.5;
    border: 1px solid transparent;
  }
  .pill:hover {
    color: var(--color-text);
    background: var(--filter-pill-hover-bg);
    border-color: var(--filter-pill-hover-border);
  }
  .pill:active {
    transform: scale(0.94);
  }

  .pill[data-active="true"] {
    color: #fff;
    background: var(--bar-accent);
    border-color: transparent;
    box-shadow: 0 0 20px color-mix(in srgb, var(--bar-accent) 30%, transparent);
  }
  .pill[data-active="true"]:hover {
    filter: brightness(1.1);
  }

  /* Year pill — smaller & subtle */
  .year-pill {
    font-size: 0.675rem;
    padding: 0.15rem 0.5rem;
    opacity: 0.5;
  }
  .year-pill:hover {
    opacity: 0.8;
  }
  .year-pill[data-active="true"] {
    opacity: 1;
  }

  /* ════════ Light theme ════════ */
  [data-theme="light"] .filter-bar {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-color: rgba(0, 0, 0, 0.05);
    box-shadow:
      0 0 30px color-mix(in srgb, rgba(var(--bar-accent-rgb), 0.06), transparent),
      0 4px 24px rgba(0, 0, 0, 0.03);
  }
  /* ════════ Mobile ════════ */
  @media (max-width: 480px) {
    .filter-bar {
      padding: 0.625rem 0.75rem;
      border-radius: 14px;
      gap: 0.5rem;
    }
    .search-wrap {
      padding: 0.45rem 0.625rem;
      border-radius: 10px;
    }
    .search-input {
      font-size: 0.8125rem;
    }
    .pill {
      font-size: 0.7rem;
      padding: 0.15rem 0.5rem;
    }
    .year-pill {
      font-size: 0.625rem;
      padding: 0.1rem 0.4rem;
    }
    .filter-row {
      gap: 0.375rem;
    }
    .filter-pills {
      gap: 0.15rem;
    }
    .year-pills {
      margin-left: 0;
    }
  }

  /* ════════ Result Count ════════ */
  .result-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .result-count.visible {
    opacity: 0.7;
  }

  /* ════════ Clear Button ════════ */
  .search-clear {
    all: unset;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    font-size: 1rem;
    line-height: 1;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }
  .search-clear:hover {
    color: var(--color-text);
    background: rgba(255,255,255,0.08);
  }
  .search-clear.show { display: flex; }

  /* ════════ Post Animation ════════ */
  .post-card {
    transition: opacity 0.25s ease, transform 0.25s ease !important;
  }
  .post-card.filter-hidden {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }
</style>
