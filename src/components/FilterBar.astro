---
// FilterBar v3 — Ultra-minimalist
// Two rows: search (full width) + pills that wrap
// No card background, no emojis, 999px pill shape
// Mobile: pills wrap naturally, search goes edge-to-edge

export interface Props {
  years: string[];
}

const { years } = Astro.props;

const projects = [
  { id: 'all', label: 'Todos' },
  { id: 'arachne', label: 'Arachne' },
  { id: 'dogwalk', label: 'Dogwalk' },
  { id: 'portfolio', label: 'Portfólio' },
  { id: 'capivara', label: 'Capivara' },
  { id: 'estudos', label: 'Estudos' },
  { id: 'descobertas', label: 'Descobertas' },
];

const projectColors: Record<string, string> = {
  all: '#848d97',
  arachne: '#a78bfa',
  dogwalk: '#34d399',
  portfolio: '#22d3ee',
  capivara: '#fbbf24',
  estudos: '#60a5fa',
  descobertas: '#fb7185',
};
---

<div
  id="filter-bar"
  class="filter-bar"
  style="--bar-accent: #848d97;"
>
  <!-- Row 1: Search -->
  <div class="search-row">
    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        id="filter-search"
        type="text"
        placeholder="Buscar posts..."
        class="search-input"
        aria-label="Buscar posts"
      />
      <span class="search-hint"><kbd>⌘</kbd><kbd>K</kbd></span>
    </div>
  </div>

  <!-- Row 2: Pills + Year -->
  <div class="filter-row">
    <div class="filter-pills" role="radiogroup" aria-label="Filtrar por projeto">
      {projects.map((p) => (
        <button
          class="pill"
          data-filter-project={p.id}
          data-active={p.id === 'all'}
          aria-checked={p.id === 'all'}
          role="radio"
        >
          {p.label}
        </button>
      ))}
    </div>

    {years.length > 1 && (
      <div class="year-pills" role="radiogroup" aria-label="Filtrar por ano">
        <button
          class="pill year-pill"
          data-filter-year="all"
          data-active="true"
          aria-checked="true"
          role="radio"
        >
          Todos
        </button>
        {years.map((y) => (
          <button
            class="pill year-pill"
            data-filter-year={y}
            data-active="false"
            aria-checked="false"
            role="radio"
          >
            {y}
          </button>
        ))}
      </div>
    )}
  </div>
</div>

<script is:inline>
(function() {
  const bar = document.getElementById('filter-bar');
  const searchInput = document.getElementById('filter-search');
  const pills = document.querySelectorAll('[data-filter-project]');
  const yearPills = document.querySelectorAll('[data-filter-year]');

  // ===== Project colors =====
  const COLORS = {
    all: '#848d97',
    arachne: '#a78bfa',
    dogwalk: '#34d399',
    portfolio: '#22d3ee',
    capivara: '#fbbf24',
    estudos: '#60a5fa',
    descobertas: '#fb7185',
  };

  let activeProject = 'all';
  let activeYear = 'all';
  let activeSearch = '';

  // ===== Fuse.js (self-hosted) =====
  let fusePromise = null;
  function getFuse(postsData) {
    if (!fusePromise) {
      fusePromise = import('/vendor/fuse.mjs').then(
        (mod) => new mod.default(postsData, {
          keys: ['title', 'desc', 'tags', 'project'],
          threshold: 0.4,
          distance: 100,
          minMatchCharLength: 2,
        })
      );
    }
    return fusePromise;
  }

  // ===== Build post index from DOM =====
  function buildPostIndex() {
    const posts = document.querySelectorAll('.post-card');
    return Array.from(posts).map(post => ({
      el: post,
      project: post.getAttribute('data-project'),
      title: post.querySelector('h2')?.textContent || '',
      desc: post.querySelector('.card-desc')?.textContent || '',
      tags: Array.from(post.querySelectorAll('.tag')).map(t => t.textContent || ''),
      dateText: post.querySelector('[data-date]')?.textContent || '',
    }));
  }

  let postsData = buildPostIndex();

  // Rebuild on DOM changes
  if (window.MutationObserver) {
    const obs = new MutationObserver(() => { postsData = buildPostIndex(); });
    const target = document.getElementById('filter-bar');
    if (target) obs.observe(target, { childList: true, subtree: true });
  }

  // ===== Update bar accent =====
  function setBarAccent(projectId) {
    const color = COLORS[projectId] || COLORS.all;
    bar.style.setProperty('--bar-accent', color);
  }

  // ===== Pill click (projects) =====
  pills.forEach(btn => {
    btn.addEventListener('click', () => {
      const project = btn.getAttribute('data-filter-project');
      if (!project) return;

      pills.forEach(b => {
        b.setAttribute('data-active', 'false');
        b.ariaChecked = 'false';
      });
      btn.setAttribute('data-active', 'true');
      btn.ariaChecked = 'true';

      activeProject = project;
      setBarAccent(project);
      filterPosts();
    });
  });

  // ===== Year pill click =====
  yearPills.forEach(btn => {
    btn.addEventListener('click', () => {
      const year = btn.getAttribute('data-filter-year');
      if (!year) return;

      yearPills.forEach(b => {
        b.setAttribute('data-active', 'false');
        b.ariaChecked = 'false';
      });
      btn.setAttribute('data-active', 'true');
      btn.ariaChecked = 'true';

      activeYear = year;
      filterPosts();
    });
  });

  // ===== Search =====
  searchInput.addEventListener('input', () => {
    activeSearch = searchInput.value.trim();
    if (activeSearch.length < 2) {
      postsData.forEach(pd => { pd.el.style.display = ''; });
      filterPosts();
      return;
    }
    fuzzySearch(activeSearch);
  });

  // Keyboard shortcut
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchInput.blur();
      searchInput.value = '';
      activeSearch = '';
      postsData.forEach(pd => { pd.el.style.display = ''; });
      filterPosts();
    }
  });

  // Global ⌘K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // ===== Filter logic =====
  function filterPosts() {
    const searchLower = activeSearch.toLowerCase();

    postsData.forEach((pd) => {
      const yearMatch = pd.dateText.match(/\d{4}/);
      const year = yearMatch ? yearMatch[0] : '';

      const matchProject = activeProject === 'all' || pd.project === activeProject;
      const matchYear = activeYear === 'all' || year === activeYear;

      let matchSearch = true;
      if (searchLower) {
        matchSearch =
          pd.title.toLowerCase().includes(searchLower) ||
          pd.desc.toLowerCase().includes(searchLower) ||
          pd.tags.some(t => t.toLowerCase().includes(searchLower)) ||
          pd.project?.includes(searchLower);
      }

      const visible = matchProject && matchYear && matchSearch;
      pd.el.style.display = visible ? '' : 'none';
    });

    // Hide empty separator groups
    document.querySelectorAll('.date-separator').forEach(sep => {
      let next = sep.nextElementSibling;
      let hasVisible = false;
      while (next && !next.classList.contains('date-separator')) {
        if (next.classList.contains('post-card') && next.style.display !== 'none') {
          hasVisible = true;
          break;
        }
        next = next.nextElementSibling;
      }
      sep.style.display = hasVisible ? '' : 'none';
    });

    // Show/hide empty state
    const emptyEl = document.getElementById('empty-state');
    const visibleCount = postsData.filter(p => p.el.style.display !== 'none').length;
    if (emptyEl) {
      emptyEl.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  // ===== Fuzzy search =====
  async function fuzzySearch(query) {
    const q = query.toLowerCase();
    if (q.length < 2) return filterPosts();

    try {
      const fuse = await getFuse(postsData);
      const results = fuse.search(q);
      const matchedEls = new Set(results.map(r => r.item.el));

      postsData.forEach(pd => {
        if (pd.el.style.display === 'none') return;
        pd.el.style.display = matchedEls.has(pd.el) ? '' : 'none';
      });

      document.querySelectorAll('.date-separator').forEach(sep => {
        let next = sep.nextElementSibling;
        let hasVisible = false;
        while (next && !next.classList.contains('date-separator')) {
          if (next.classList.contains('post-card') && next.style.display !== 'none') {
            hasVisible = true;
            break;
          }
          next = next.nextElementSibling;
        }
        sep.style.display = hasVisible ? '' : 'none';
      });

      const emptyEl = document.getElementById('empty-state');
      const visiblePosts = postsData.filter(p => p.el.style.display !== 'none').length;
      if (emptyEl) emptyEl.style.display = visiblePosts === 0 ? '' : 'none';
    } catch (e) {
      filterPosts();
    }
  }

  // ===== Init =====
  setBarAccent('all');
})();
</script>

<style>
  .filter-bar {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ════════ Search Row ════════ */
  .search-row {
    width: 100%;
  }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.625rem 0.875rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .search-wrap:focus-within {
    border-color: var(--bar-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--bar-accent) 12%, transparent);
  }

  .search-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }
  .search-wrap:focus-within .search-icon {
    opacity: 0.8;
    color: var(--bar-accent);
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 0.875rem;
    font-family: inherit;
    min-width: 0;
  }
  .search-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .search-hint {
    display: none;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }
  .search-hint kbd {
    font-size: 0.6rem;
    padding: 1px 4px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: rgba(255,255,255,0.03);
    color: var(--color-text-muted);
    font-family: inherit;
    opacity: 0.5;
  }
  @media (min-width: 640px) {
    .search-hint { display: inline-flex; }
  }

  /* ════════ Filter Row ════════ */
  .filter-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-pills {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .year-pills {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
    margin-left: auto;
  }

  /* ════════ Pill ════════ */
  .pill {
    all: unset;
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    white-space: nowrap;
    line-height: 1.5;
    border: 1px solid transparent;
  }
  .pill:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--bar-accent) 6%, transparent);
  }
  .pill:active {
    transform: scale(0.95);
  }

  .pill[data-active="true"] {
    color: #fff;
    background: var(--bar-accent);
    border-color: transparent;
    box-shadow: 0 0 16px color-mix(in srgb, var(--bar-accent) 30%, transparent);
  }
  .pill[data-active="true"]:hover {
    filter: brightness(1.1);
  }

  /* Year pill — smaller */
  .year-pill {
    font-size: 0.675rem;
    padding: 0.2rem 0.55rem;
    opacity: 0.6;
  }
  .year-pill[data-active="true"] {
    opacity: 1;
  }

  /* ════════ Mobile tweaks ════════ */
  @media (max-width: 480px) {
    .search-wrap {
      padding: 0.55rem 0.75rem;
      border-radius: 14px;
    }
    .search-input {
      font-size: 0.8125rem;
    }
    .pill {
      font-size: 0.7rem;
      padding: 0.2rem 0.55rem;
    }
    .year-pill {
      font-size: 0.625rem;
      padding: 0.15rem 0.45rem;
    }
    .filter-row {
      gap: 0.375rem;
    }
    .filter-pills {
      gap: 0.2rem;
    }
    .year-pills {
      margin-left: 0;
    }
  }

  /* ════════ Light theme ════════ */
  [data-theme="light"] .search-wrap {
    background: rgba(0,0,0,0.02);
    border-color: rgba(0,0,0,0.08);
  }
  [data-theme="light"] .search-wrap:focus-within {
    border-color: var(--bar-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--bar-accent) 15%, transparent);
  }
  [data-theme="light"] .pill:hover {
    background: color-mix(in srgb, var(--bar-accent) 8%, transparent);
  }
</style>
