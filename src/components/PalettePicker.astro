---
// PalettePicker — Theme, Palette & Language Control
// Minimal, sempre visível, elementos minúsculos e discretos
import { PALETTES, DEFAULT_PALETTE } from '../lib/palettes'
---

<div id="theme-rail" class="theme-rail">
  <!-- Botão toggle (🎨) — MESMO TAMANHO, Samuel pediu -->
  <button id="rail-toggle" class="rail-toggle" aria-label="Personalizar" title="Personalizar">
    <span class="rail-toggle-inner">
      <span id="rail-indicator" class="rail-indicator" style="background: #a78bfa"></span>
      <span class="rail-toggle-icon">🎨</span>
    </span>
  </button>

  <!-- 🌙/☀️ Tema — sempre visível -->
  <button id="rail-theme" class="rail-theme-btn" aria-label="Alternar tema claro/escuro" title="Alternar tema">
    <span id="rail-theme-icon">🌙</span>
  </button>

  <!-- 🎨 Paletas (6 cores) — sempre visível -->
  <div class="rail-palettes" role="radiogroup" aria-label="Paletas de cor">
    {PALETTES.map(p => (
      <button
        class="rail-dot"
        data-palette={p.id}
        title={p.name}
        role="radio"
        aria-checked={p.id === DEFAULT_PALETTE}
        style={`--dot-bg: ${p.accentDark}`}
      ></button>
    ))}
  </div>

  <!-- 🇧🇷🇺🇸 Idioma — sempre visível -->
  <div class="rail-lang" role="radiogroup" aria-label="Idioma">
    <button class="rail-lang-btn" data-lang="pt" role="radio" aria-checked="true" title="Português">PT</button>
    <button class="rail-lang-btn" data-lang="en" role="radio" aria-checked="false" title="English">EN</button>
  </div>
</div>

<script is:inline>
(function() {
  const LOCALE_KEY = 'lifelog-locale'

  /* ═══════════════════════════════════════
     Paletas (inline data)
     ═══════════════════════════════════════ */
  const PALETTES = [
    {id:"purple",  name:"Roxo",    accentDark:"#a78bfa", accentLight:"#7c3aed", borderDark:"rgba(167,139,250,0.25)", borderLight:"rgba(124,58,237,0.2)", glowDark:"0 0 30px rgba(167,139,250,0.15)", glowLight:"0 4px 24px rgba(124,58,237,0.12)", tagBg:"rgba(167,139,250,0.12)", particleDark:"rgba(200,180,255,0.6)", particleLight:"rgba(124,58,237,0.15)", auraDark:"radial-gradient(ellipse at 30% 20%, rgba(167,139,250,0.06) 0%, transparent 60%)", auraLight:"radial-gradient(ellipse at 80% 10%, rgba(124,58,237,0.04) 0%, transparent 50%)", shadowDark:"0 8px 32px rgba(167,139,250,0.06)", shadowLight:"0 4px 16px rgba(124,58,237,0.06)"},
    {id:"cyan",    name:"Ciano",   accentDark:"#22d3ee", accentLight:"#0891b2", borderDark:"rgba(34,211,238,0.25)", borderLight:"rgba(8,145,178,0.2)", glowDark:"0 0 30px rgba(34,211,238,0.15)", glowLight:"0 4px 24px rgba(8,145,178,0.12)", tagBg:"rgba(34,211,238,0.12)", particleDark:"rgba(150,230,255,0.6)", particleLight:"rgba(8,145,178,0.15)", auraDark:"radial-gradient(ellipse at 20% 30%, rgba(34,211,238,0.06) 0%, transparent 60%)", auraLight:"radial-gradient(ellipse at 70% 15%, rgba(8,145,178,0.04) 0%, transparent 50%)", shadowDark:"0 8px 32px rgba(34,211,238,0.06)", shadowLight:"0 4px 16px rgba(8,145,178,0.06)"},
    {id:"emerald", name:"Verde",   accentDark:"#34d399", accentLight:"#059669", borderDark:"rgba(52,211,153,0.25)", borderLight:"rgba(5,150,105,0.2)", glowDark:"0 0 30px rgba(52,211,153,0.15)", glowLight:"0 4px 24px rgba(5,150,105,0.12)", tagBg:"rgba(52,211,153,0.12)", particleDark:"rgba(150,240,200,0.6)", particleLight:"rgba(5,150,105,0.15)", auraDark:"radial-gradient(ellipse at 40% 20%, rgba(52,211,153,0.05) 0%, transparent 60%)", auraLight:"radial-gradient(ellipse at 60% 10%, rgba(5,150,105,0.04) 0%, transparent 50%)", shadowDark:"0 8px 32px rgba(52,211,153,0.06)", shadowLight:"0 4px 16px rgba(5,150,105,0.06)"},
    {id:"amber",   name:"Âmbar",   accentDark:"#fbbf24", accentLight:"#d97706", borderDark:"rgba(251,191,36,0.25)", borderLight:"rgba(217,119,6,0.2)", glowDark:"0 0 30px rgba(251,191,36,0.15)", glowLight:"0 4px 24px rgba(217,119,6,0.12)", tagBg:"rgba(251,191,36,0.12)", particleDark:"rgba(255,220,150,0.6)", particleLight:"rgba(217,119,6,0.15)", auraDark:"radial-gradient(ellipse at 50% 30%, rgba(251,191,36,0.05) 0%, transparent 60%)", auraLight:"radial-gradient(ellipse at 85% 10%, rgba(217,119,6,0.04) 0%, transparent 50%)", shadowDark:"0 8px 32px rgba(251,191,36,0.06)", shadowLight:"0 4px 16px rgba(217,119,6,0.06)"},
    {id:"rose",    name:"Rosa",    accentDark:"#fb7185", accentLight:"#e11d48", borderDark:"rgba(251,113,133,0.25)", borderLight:"rgba(225,29,72,0.2)", glowDark:"0 0 30px rgba(251,113,133,0.15)", glowLight:"0 4px 24px rgba(225,29,72,0.12)", tagBg:"rgba(251,113,133,0.12)", particleDark:"rgba(255,180,200,0.6)", particleLight:"rgba(225,29,72,0.12)", auraDark:"radial-gradient(ellipse at 30% 40%, rgba(251,113,133,0.05) 0%, transparent 60%)", auraLight:"radial-gradient(ellipse at 75% 15%, rgba(225,29,72,0.04) 0%, transparent 50%)", shadowDark:"0 8px 32px rgba(251,113,133,0.06)", shadowLight:"0 4px 16px rgba(225,29,72,0.06)"},
    {id:"blue",    name:"Azul",    accentDark:"#60a5fa", accentLight:"#2563eb", borderDark:"rgba(96,165,250,0.25)", borderLight:"rgba(37,99,235,0.2)", glowDark:"0 0 30px rgba(96,165,250,0.15)", glowLight:"0 4px 24px rgba(37,99,235,0.12)", tagBg:"rgba(96,165,250,0.12)", particleDark:"rgba(160,200,255,0.6)", particleLight:"rgba(37,99,235,0.15)", auraDark:"radial-gradient(ellipse at 25% 25%, rgba(96,165,250,0.05) 0%, transparent 60%)", auraLight:"radial-gradient(ellipse at 65% 10%, rgba(37,99,235,0.04) 0%, transparent 50%)", shadowDark:"0 8px 32px rgba(96,165,250,0.06)", shadowLight:"0 4px 16px rgba(37,99,235,0.06)"},
  ]
  const STORAGE_KEY = 'lifelog-palette'
  const THEME_KEY = 'lifelog-theme'
  const DEFAULT = 'purple'

  /* ─── Paletas ─── */
  function getSavedPalette() {
    try { const s = localStorage.getItem(STORAGE_KEY); if (s && PALETTES.some(p => p.id === s)) return s } catch {}
    return DEFAULT
  }

  function setPalette(id, save = true) {
    const p = PALETTES.find(p => p.id === id)
    if (!p) return
    const isDark = document.documentElement.getAttribute('data-theme') !== 'light'
    const root = document.documentElement
    const accent = isDark ? p.accentDark : p.accentLight

    root.style.setProperty('--color-accent', accent)
    root.style.setProperty('--color-accent-soft', p.tagBg)
    root.style.setProperty('--color-glow', isDark ? p.glowDark : p.glowLight)
    root.style.setProperty('--color-border', isDark ? p.borderDark : p.borderLight)
    root.style.setProperty('--particle-color', isDark ? p.particleDark : p.particleLight)
    root.style.setProperty('--aura-gradient', isDark ? p.auraDark : p.auraLight)
    root.style.setProperty('--card-shadow', isDark ? p.shadowDark : p.shadowLight)

    const indicator = document.getElementById('rail-indicator')
    if (indicator) indicator.style.background = p.accentDark

    if (save) try { localStorage.setItem(STORAGE_KEY, id) } catch {}

    document.querySelectorAll('.rail-dot').forEach(el => {
      el.setAttribute('aria-checked', el.dataset.palette === id ? 'true' : 'false')
    })
  }

  /* ─── Tema ─── */
  function getSavedTheme() {
    try { return localStorage.getItem(THEME_KEY) } catch { return null }
  }

  function setTheme(theme, save = true) {
    document.documentElement.setAttribute('data-theme', theme)
    document.documentElement.classList.toggle('dark', theme !== 'light')
    document.documentElement.classList.toggle('light', theme === 'light')
    if (save) try { localStorage.setItem(THEME_KEY, theme) } catch {}
    const icon = document.getElementById('rail-theme-icon')
    if (icon) icon.textContent = theme === 'light' ? '☀️' : '🌙'
    setPalette(getSavedPalette(), false)
  }

  function toggleTheme(event) {
    const current = document.documentElement.getAttribute('data-theme')
    const newTheme = current === 'light' ? 'dark' : 'light'

    if (document.startViewTransition) {
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
        setTheme(newTheme); return
      }
      const x = event?.clientX ?? innerWidth / 2
      const y = event?.clientY ?? innerHeight / 2
      const t = document.startViewTransition(() => setTheme(newTheme))
      t.ready.then(() => {
        const r = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y))
        document.documentElement.animate(
          { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${r}px at ${x}px ${y}px)`] },
          { duration: 600, easing: 'ease-in-out', pseudoElement: '::view-transition-new(root)' },
        )
      })
      return
    }

    if (event && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const overlay = document.createElement('div')
      overlay.style.cssText = `
        position: fixed; inset: 0; z-index: 9999;
        pointer-events: none;
        clip-path: circle(0px at ${event.clientX}px ${event.clientY}px);
        background: ${newTheme === 'light' ? '#f7f6f3' : '#0a0a0f'};
        transition: clip-path 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      `
      document.body.appendChild(overlay)
      overlay.offsetHeight
      const endR = Math.hypot(Math.max(event.clientX, innerWidth - event.clientX), Math.max(event.clientY, innerHeight - event.clientY))
      overlay.style.clipPath = `circle(${endR}px at ${event.clientX}px ${event.clientY}px)`
      setTimeout(() => setTheme(newTheme), 200)
      setTimeout(() => overlay.remove(), 550)
    } else {
      setTheme(newTheme)
    }
  }

  /* ─── Idioma ─── */
  function getSavedLocale() {
    try { const s = localStorage.getItem(LOCALE_KEY); if (s === 'pt' || s === 'en') return s } catch {}
    return 'pt'
  }

  function setLocale(locale, save = true) {
    document.documentElement.setAttribute('lang', locale === 'en' ? 'en' : 'pt-BR')
    document.querySelectorAll('.rail-lang-btn').forEach(el => {
      el.setAttribute('aria-checked', el.dataset.lang === locale ? 'true' : 'false')
    })
    if (save) try { localStorage.setItem(LOCALE_KEY, locale) } catch {}
    document.dispatchEvent(new CustomEvent('lifelog-locale-change', { detail: { locale } }))
  }

  /* ─── Init ─── */
  const savedTheme = getSavedTheme() || 'dark'
  setTheme(savedTheme, false)
  setPalette(getSavedPalette(), false)
  const savedLocale = getSavedLocale()
  document.documentElement.setAttribute('lang', savedLocale === 'en' ? 'en' : 'pt-BR')

  /* ─── Listen for palette-reapply from FilterBar ─── */
  document.addEventListener('lifelog-palette-reapply', function(e) {
    const palette = e.detail && e.detail.palette;
    if (palette) setPalette(palette, false);
  });

  /* ─── Eventos ─── */
  document.addEventListener('click', (e) => {
    const dot = e.target.closest('.rail-dot')
    if (dot) {
      setPalette(dot.dataset.palette)
      return
    }

    const themeBtn = e.target.closest('#rail-theme')
    if (themeBtn) {
      toggleTheme(e)
      return
    }

    const langBtn = e.target.closest('.rail-lang-btn')
    if (langBtn) {
      setLocale(langBtn.dataset.lang)
      return
    }
  })
})()
</script>

<style>
  /* ═══════════════════════════════════════════
     Theme Rail — Container
     display: flex padrão (LTR), TUDO SEMPRE VISÍVEL
     ═══════════════════════════════════════════ */
  .theme-rail {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
    z-index: 100;
  }

  /* ═══════════════════════════════════════════
     Botão Toggle — Glass Pill (MESMO TAMANHO)
     ═══════════════════════════════════════════ */
  .rail-toggle {
    all: unset;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.2s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    flex-shrink: 0;
  }
  .rail-toggle:hover {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
  .rail-toggle:active { transform: scale(0.94); }
  :global([data-theme="light"]) .rail-toggle {
    background: rgba(0,0,0,0.03);
    border-color: rgba(0,0,0,0.06);
  }
  :global([data-theme="light"]) .rail-toggle:hover {
    background: rgba(99,102,241,0.06);
    border-color: #6366f1;
    box-shadow: 0 0 16px rgba(99,102,241,0.15);
  }

  .rail-toggle-inner {
    display: flex;
    align-items: center;
    gap: 6px;
    line-height: 1;
  }
  .rail-indicator {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    transition: background 0.3s ease;
    flex-shrink: 0;
    box-shadow: 0 0 6px currentColor;
  }
  .rail-toggle-icon {
    font-size: 1rem;
    line-height: 1;
  }

  /* ═══════════════════════════════════════════
     🌙/☀️ Botão de Tema — minúsculo e discreto
     ═══════════════════════════════════════════ */
  .rail-theme-btn {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 4px;
    font-size: 0.7rem;
    line-height: 1;
    transition: all 0.2s ease;
    flex-shrink: 0;
    opacity: 0.5;
  }
  .rail-theme-btn:hover {
    opacity: 1;
    background: var(--color-accent-soft);
    transform: scale(1.1);
  }
  .rail-theme-btn:active { transform: scale(0.9); }

  /* ═══════════════════════════════════════════
     Paletas (6 dots) — bolinhas minúsculas
     ═══════════════════════════════════════════ */
  .rail-palettes {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .rail-dot {
    all: unset;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--dot-bg);
    opacity: 0.35;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    flex-shrink: 0;
  }
  .rail-dot:hover {
    opacity: 0.8;
    transform: scale(1.3);
  }
  .rail-dot[aria-checked="true"] {
    opacity: 0.85;
    transform: scale(1.2);
    box-shadow: 0 0 8px var(--dot-bg);
  }
  .rail-dot[aria-checked="true"]::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.3);
  }
  :global([data-theme="light"]) .rail-dot[aria-checked="true"]::after {
    border-color: rgba(0,0,0,0.3);
  }

  /* ═══════════════════════════════════════════
     🇧🇷🇺🇸 Idioma — PT/EN minúsculo
     ═══════════════════════════════════════════ */
  .rail-lang {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .rail-lang-btn {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px 3px;
    border-radius: 3px;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.4);
    transition: all 0.2s ease;
    line-height: 1;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .rail-lang-btn:hover {
    color: var(--color-accent);
    opacity: 1;
  }
  .rail-lang-btn[aria-checked="true"] {
    color: var(--color-accent);
    opacity: 0.9;
  }
  :global([data-theme="light"]) .rail-lang-btn {
    color: rgba(0,0,0,0.35);
  }
  :global([data-theme="light"]) .rail-lang-btn[aria-checked="true"] {
    color: var(--color-accent);
  }
</style>
