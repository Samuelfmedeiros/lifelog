---
// ThemeRail — Controls: tema, cor (dropdown), idioma
// Layout: [🌙] [🎨 ▼] [PT]
// Paleta abre dropdown pra baixo com 6 dots
import { PALETTES, DEFAULT_PALETTE } from '../lib/palettes'
---

<div id="theme-rail" class="theme-rail">
  <!-- 🌙 Theme Toggle -->
  <button id="rail-theme" class="rail-btn" aria-label="Alternar tema" title="Alternar tema">
    <span id="rail-theme-icon" class="rail-icon">🌙</span>
  </button>

  <!-- 🎨 Color Button (abre dropdown pra baixo) -->
  <div class="rail-color-wrap">
    <button id="rail-color" class="rail-btn rail-btn-color" aria-label="Paleta de cores" title="Paleta de cores">
      <span class="rail-palette-indicator" id="rail-indicator"></span>
    </button>
    <div id="rail-color-dropdown" class="rail-dropdown">
      {PALETTES.map((p, i) => (
        <button
          id={`rail-palette-${i}`}
          class="rail-dot"
          style={`--dot-color: ${p.accentDark}`}
          data-palette={p.id}
          aria-label={`Paleta ${p.name}`}
          title={p.name}
        ></button>
      ))}
    </div>
  </div>

  <!-- PT/EN Language Toggle -->
  <button id="rail-lang" class="rail-btn rail-btn-lang" aria-label="Alternar idioma" title="Alternar idioma">
    <span id="rail-lang-text" class="rail-lang-text">PT</span>
  </button>
</div>

<style>
  /* ═══════════════════════════════════════════
     Theme Rail — Inline controls + color dropdown
     ═══════════════════════════════════════════ */
  .theme-rail {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  /* ─── Shared button style ─── */
  .rail-btn {
    all: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    transition: all 0.2s ease;
    flex-shrink: 0;
    opacity: 0.7;
    position: relative;
  }
  .rail-btn:hover {
    opacity: 1;
    background: var(--color-accent-soft);
    transform: scale(1.08);
  }
  .rail-btn:active { transform: scale(0.92); }
  .rail-icon {
    font-size: 1.15rem;
    line-height: 1;
    pointer-events: none;
  }

  /* ─── Color button ─── */
  .rail-color-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .rail-btn-color {
    font-size: 0;
  }
  .rail-palette-indicator {
    display: block;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid color-mix(in srgb, var(--color-accent) 50%, transparent);
    transition: all 0.3s ease;
    pointer-events: none;
    box-sizing: border-box;
    flex-shrink: 0;
  }

  /* ─── Dropdown (abre pra baixo) ─── */
  .rail-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    display: flex;
    gap: 5px;
    padding: 8px 10px;
    background: color-mix(in srgb, var(--color-bg) 95%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 100;
    white-space: nowrap;
  }
  .rail-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* ─── Palette dots ─── */
  .rail-dot {
    all: unset;
    cursor: pointer;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--dot-color);
    opacity: 0.5;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }
  .rail-dot:hover {
    opacity: 0.9;
    transform: scale(1.25);
  }
  .rail-dot:active { transform: scale(0.9); }
  .rail-dot.active {
    opacity: 1;
    border-color: var(--color-accent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--color-accent) 50%, transparent);
    transform: scale(1.2);
  }

  /* ─── Language ─── */
  .rail-btn-lang {
    min-width: 32px;
    padding: 0 6px;
  }
  .rail-lang-text {
    font-size: 0.72rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    line-height: 1;
    pointer-events: none;
  }

  /* ─── Mobile ─── */
  @media (max-width: 768px) {
    .rail-btn { width: 30px; height: 30px; }
    .rail-icon { font-size: 1rem; }
    .rail-palette-indicator { width: 16px; height: 16px; }
    .rail-dot { width: 16px; height: 16px; }
    .rail-btn-lang { min-width: 28px; padding: 0 5px; }
    .rail-lang-text { font-size: 0.65rem; }
    .rail-dropdown { padding: 7px 9px; gap: 5px; }
  }
  @media (max-width: 480px) {
    .rail-btn { width: 30px; height: 30px; }
    .rail-icon { font-size: 0.95rem; }
    .rail-palette-indicator { width: 16px; height: 16px; }
    .rail-dot { width: 18px; height: 18px; }
    .rail-btn-lang { min-width: 28px; padding: 0 5px; }
    .rail-lang-text { font-size: 0.65rem; }
    .rail-dropdown {
      padding: 8px 10px; gap: 6px;
      left: auto; right: 0;
      transform: translateX(0) translateY(-4px);
      transform-origin: top right;
    }
    .rail-dropdown.open {
      transform: translateX(0) translateY(0);
    }
  }
</style>

<script is:inline>
(function() {
  const LOCALE_KEY = 'lifelog-locale'
  const PALETTE_KEY = 'lifelog-palette'
  const THEME_KEY = 'lifelog-theme'

  const PALETTES = [
    {id:"purple",name:"Roxo",aD:"#a78bfa",aL:"#7c3aed",bD:"rgba(167,139,250,0.25)",bL:"rgba(124,58,237,0.2)",gD:"0 0 30px rgba(167,139,250,0.15)",gL:"0 4px 24px rgba(124,58,237,0.12)",tB:"rgba(167,139,250,0.12)",pD:"rgba(200,180,255,0.6)",pL:"rgba(124,58,237,0.15)",aD2:"radial-gradient(ellipse at 30% 20%, rgba(167,139,250,0.06) 0%, transparent 60%)",aL2:"radial-gradient(ellipse at 80% 10%, rgba(124,58,237,0.04) 0%, transparent 50%)",sD:"0 8px 32px rgba(167,139,250,0.06)",sL:"0 4px 16px rgba(124,58,237,0.06)"},
    {id:"cyan",name:"Ciano",aD:"#22d3ee",aL:"#0891b2",bD:"rgba(34,211,238,0.25)",bL:"rgba(8,145,178,0.2)",gD:"0 0 30px rgba(34,211,238,0.15)",gL:"0 4px 24px rgba(8,145,178,0.12)",tB:"rgba(34,211,238,0.12)",pD:"rgba(150,230,255,0.6)",pL:"rgba(8,145,178,0.15)",aD2:"radial-gradient(ellipse at 20% 30%, rgba(34,211,238,0.06) 0%, transparent 60%)",aL2:"radial-gradient(ellipse at 70% 15%, rgba(8,145,178,0.04) 0%, transparent 50%)",sD:"0 8px 32px rgba(34,211,238,0.06)",sL:"0 4px 16px rgba(8,145,178,0.06)"},
    {id:"emerald",name:"Verde",aD:"#34d399",aL:"#059669",bD:"rgba(52,211,153,0.25)",bL:"rgba(5,150,105,0.2)",gD:"0 0 30px rgba(52,211,153,0.15)",gL:"0 4px 24px rgba(5,150,105,0.12)",tB:"rgba(52,211,153,0.12)",pD:"rgba(150,240,200,0.6)",pL:"rgba(5,150,105,0.15)",aD2:"radial-gradient(ellipse at 40% 20%, rgba(52,211,153,0.05) 0%, transparent 60%)",aL2:"radial-gradient(ellipse at 60% 10%, rgba(5,150,105,0.04) 0%, transparent 50%)",sD:"0 8px 32px rgba(52,211,153,0.06)",sL:"0 4px 16px rgba(5,150,105,0.06)"},
    {id:"amber",name:"Âmbar",aD:"#fbbf24",aL:"#d97706",bD:"rgba(251,191,36,0.25)",bL:"rgba(217,119,6,0.2)",gD:"0 0 30px rgba(251,191,36,0.15)",gL:"0 4px 24px rgba(217,119,6,0.12)",tB:"rgba(251,191,36,0.12)",pD:"rgba(255,220,150,0.6)",pL:"rgba(217,119,6,0.15)",aD2:"radial-gradient(ellipse at 50% 30%, rgba(251,191,36,0.05) 0%, transparent 60%)",aL2:"radial-gradient(ellipse at 85% 10%, rgba(217,119,6,0.04) 0%, transparent 50%)",sD:"0 8px 32px rgba(251,191,36,0.06)",sL:"0 4px 16px rgba(217,119,6,0.06)"},
    {id:"rose",name:"Rosa",aD:"#fb7185",aL:"#e11d48",bD:"rgba(251,113,133,0.25)",bL:"rgba(225,29,72,0.2)",gD:"0 0 30px rgba(251,113,133,0.15)",gL:"0 4px 24px rgba(225,29,72,0.12)",tB:"rgba(251,113,133,0.12)",pD:"rgba(255,180,200,0.6)",pL:"rgba(225,29,72,0.12)",aD2:"radial-gradient(ellipse at 30% 40%, rgba(251,113,133,0.05) 0%, transparent 60%)",aL2:"radial-gradient(ellipse at 75% 15%, rgba(225,29,72,0.04) 0%, transparent 50%)",sD:"0 8px 32px rgba(251,113,133,0.06)",sL:"0 4px 16px rgba(225,29,72,0.06)"},
    {id:"blue",name:"Azul",aD:"#60a5fa",aL:"#2563eb",bD:"rgba(96,165,250,0.25)",bL:"rgba(37,99,235,0.2)",gD:"0 0 30px rgba(96,165,250,0.15)",gL:"0 4px 24px rgba(37,99,235,0.12)",tB:"rgba(96,165,250,0.12)",pD:"rgba(160,200,255,0.6)",pL:"rgba(37,99,235,0.15)",aD2:"radial-gradient(ellipse at 25% 25%, rgba(96,165,250,0.05) 0%, transparent 60%)",aL2:"radial-gradient(ellipse at 65% 10%, rgba(37,99,235,0.04) 0%, transparent 50%)",sD:"0 8px 32px rgba(96,165,250,0.06)",sL:"0 4px 16px rgba(37,99,235,0.06)"},
  ]
  function getP(id) { return PALETTES.find(p => p.id === id) || PALETTES[0] }

  function getSaved(k, d) { try { const v = localStorage.getItem(k); if (v) return v } catch {} return d }
  function save(k, v) { try { localStorage.setItem(k, v) } catch {} }

  function isDark() { return document.documentElement.getAttribute('data-theme') !== 'light' }

  /* ─── Palette ─── */
  function applyPalette(id, persist) {
    const p = getP(id)
    const dark = isDark()
    const root = document.documentElement
    root.style.setProperty('--color-accent', dark ? p.aD : p.aL)
    root.style.setProperty('--color-accent-soft', p.tB)
    root.style.setProperty('--color-glow', dark ? p.gD : p.gL)
    root.style.setProperty('--color-border', dark ? p.bD : p.bL)
    root.style.setProperty('--particle-color', dark ? p.pD : p.pL)
    root.style.setProperty('--aura-gradient', dark ? p.aD2 : p.aL2)
    root.style.setProperty('--card-shadow', dark ? p.sD : p.sL)
    // indicator dot
    const ind = document.getElementById('rail-indicator')
    if (ind) ind.style.background = dark ? p.aD : p.aL
    // highlight dots
    document.querySelectorAll('.rail-dot').forEach(el => {
      el.classList.toggle('active', el.dataset.palette === id)
    })
    if (persist !== false) save(PALETTE_KEY, id)
    document.dispatchEvent(new CustomEvent('lifelog-palette-change', { detail: { palette: id } }))
  }

  /* ─── Theme ─── */
  function setTheme(theme, persist) {
    const root = document.documentElement
    root.setAttribute('data-theme', theme)
    root.classList.toggle('dark', theme !== 'light')
    root.classList.toggle('light', theme === 'light')
    const icon = document.getElementById('rail-theme-icon')
    if (icon) icon.textContent = theme === 'light' ? '☀️' : '🌙'
    const pid = getSaved(PALETTE_KEY, 'purple')
    applyPalette(pid, false)
    if (persist !== false) save(THEME_KEY, theme)
    document.dispatchEvent(new CustomEvent('lifelog-theme-change', { detail: { theme } }))
  }

  function toggleTheme(e) {
    const cur = document.documentElement.getAttribute('data-theme')
    const next = cur === 'light' ? 'dark' : 'light'

    if (document.startViewTransition && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const x = e?.clientX ?? innerWidth/2, y = e?.clientY ?? innerHeight/2
      const r = Math.hypot(Math.max(x, innerWidth-x), Math.max(y, innerHeight-y))
      const t = document.startViewTransition(() => setTheme(next))
      t.ready.then(() => {
        document.documentElement.animate(
          { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${r}px at ${x}px ${y}px)`] },
          { duration: 500, easing: 'ease-in-out', pseudoElement: '::view-transition-new(root)' }
        );
      }).catch(() => {
        // View Transition não completou — garante que o tema foi aplicado
        setTheme(next)
      });
      return
    }

    // Fallback: overlay com clip-path, lendo cor do tema destino via seletor
    if (e && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Cria um elemento temporário com o tema destino pra ler a cor real
      const tmp = document.createElement('div')
      tmp.setAttribute('data-theme', next)
      tmp.style.display = 'none'
      document.body.appendChild(tmp)
      const bg = getComputedStyle(tmp).getPropertyValue('--color-bg').trim() || (next === 'light' ? '#f5f2eb' : '#0a0a0f')
      tmp.remove()

      const o = document.createElement('div')
      o.style.cssText = `position:fixed;inset:0;z-index:9999;pointer-events:none;background:${bg};clip-path:circle(0px at ${e.clientX}px ${e.clientY}px);transition:clip-path 0.5s cubic-bezier(0.4,0,0.2,1)`
      document.body.appendChild(o)
      // Aplica o tema ANTES de expandir o círculo
      setTheme(next)
      // Força reflow e expande
      o.offsetHeight
      const r = Math.hypot(Math.max(e.clientX, innerWidth-e.clientX), Math.max(e.clientY, innerHeight-e.clientY))
      o.style.clipPath = `circle(${r}px at ${e.clientX}px ${e.clientY}px)`
      setTimeout(() => o.remove(), 550)
    } else {
      setTheme(next)
    }
  }

  /* ─── Language ─── */
  let currentLang = 'pt'
  function setLocale(locale, persist) {
    currentLang = locale
    document.documentElement.setAttribute('lang', locale === 'en' ? 'en' : 'pt-BR')
    const t = document.getElementById('rail-lang-text')
    if (t) t.textContent = locale === 'en' ? 'EN' : 'PT'
    if (persist !== false) save(LOCALE_KEY, locale)
    document.dispatchEvent(new CustomEvent('lifelog-locale-change', { detail: { locale } }))
  }

  /* ─── Dropdown toggle ─── */
  function toggleDropdown(e) {
    e.stopPropagation()
    const dd = document.getElementById('rail-color-dropdown')
    if (!dd) return
    const wasOpen = dd.classList.contains('open')
    // close all dropdowns
    document.querySelectorAll('.rail-dropdown.open').forEach(el => el.classList.remove('open'))
    if (!wasOpen) dd.classList.add('open')
  }

  /* ─── Init ─── */
  const savedTheme = getSaved(THEME_KEY, 'dark')
  setTheme(savedTheme, false)
  const savedPalette = getSaved(PALETTE_KEY, 'purple')
  applyPalette(savedPalette, false)
  const savedLocale = getSaved(LOCALE_KEY, 'pt')
  setLocale(savedLocale, false)

  /* ─── Events ─── */
  document.addEventListener('click', function(e) {
    const t = e.target
    // Theme
    if (t.closest('#rail-theme')) { toggleTheme(e); return }
    // Color button → toggle dropdown
    if (t.closest('#rail-color')) { toggleDropdown(e); return }
    // Palette dot inside dropdown
    const dot = t.closest('.rail-dot')
    if (dot && dot.dataset.palette) {
      applyPalette(dot.dataset.palette)
      document.querySelectorAll('.rail-dropdown.open').forEach(el => el.classList.remove('open'))
      return
    }
    // Language
    if (t.closest('#rail-lang')) {
      const next = currentLang === 'pt' ? 'en' : 'pt'
      setLocale(next)
      const path = window.location.pathname
      const newPath = next === 'en'
        ? (path === '/' ? '/en/' : '/en' + path)
        : path.replace(/^\/en/, '') || '/'

      // Transição suave antes de navegar
      if (document.startViewTransition) {
        document.startViewTransition(() => {
          window.location.href = newPath
        })
      } else {
        // Fallback: fade-out rápido via overlay
        const o = document.createElement('div')
        o.style.cssText = 'position:fixed;inset:0;z-index:9999;background:var(--color-bg);opacity:0;transition:opacity 0.15s ease;pointer-events:none'
        document.body.appendChild(o)
        requestAnimationFrame(() => {
          o.style.opacity = '1'
          setTimeout(() => { window.location.href = newPath }, 180)
        })
      }
      return
    }
    // Click outside → close dropdown
    if (!t.closest('.rail-color-wrap')) {
      document.querySelectorAll('.rail-dropdown.open').forEach(el => el.classList.remove('open'))
    }
  })

  document.addEventListener('lifelog-palette-reapply', function(e) {
    const pid = e.detail && e.detail.palette
    if (pid) applyPalette(pid, false)
  })
})()
</script>
