---
import ProjectIcon from './ProjectIcon.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  project: string;
  tags: string[];
  slug: string;
  icon?: string;
}

const { title, description, date, project, tags, slug, icon } = Astro.props;
const formattedDate = date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
const projectLabels: Record<string, string> = {
  arachne: 'Arachne', dogwalk: 'Dogwalk', portfolio: 'Portfólio',
  capivara: 'Capivara', estudos: 'Estudos', descobertas: 'Descobertas',
};
const projectIcons: Record<string, string> = {
  arachne: '🕷️', dogwalk: '🐶', portfolio: '🚀',
  capivara: '🐷', estudos: '📚', descobertas: '💡',
};
---

<article class="post-card" data-project={project}>
  <a href={`/post/${slug}`} class="no-underline! block">
    <div class="flex items-start gap-4">
      <ProjectIcon project={project} emoji={icon} />
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <span class="flex items-center gap-1 text-xs font-medium uppercase tracking-wider" style="color: var(--color-accent)">
            {projectIcons[project] || '📝'} {projectLabels[project] || project}
          </span>
          <span class="text-xs opacity-50">·</span>
          <span class="text-xs" data-date style="color: var(--color-text-muted)">
            {formattedDate}
          </span>
        </div>
        <h2 class="text-lg font-bold mb-2 leading-snug" style="color: #fff">
          {title}
        </h2>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted)">
          {description}
        </p>
        <div class="flex items-center gap-2 flex-wrap">
          {tags.slice(0, 4).map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <div class="mt-4 flex items-center gap-1 text-xs font-medium tracking-wide uppercase" style="color: var(--color-accent)">
          Continuar lendo
          <span class="inline-block transition-transform duration-200">→</span>
        </div>
      </div>
    </div>
  </a>
</article>
